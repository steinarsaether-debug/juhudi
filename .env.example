# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=juhudi_kilimo
DB_USER=juhudi
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://juhudi:CHANGE_ME_STRONG_PASSWORD@localhost:5432/juhudi_kilimo

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING

# AES-256-GCM keys for PII field-level encryption
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_KEY
# Generate with: openssl rand -hex 16
ENCRYPTION_IV_KEY=CHANGE_ME_16_BYTE_HEX_KEY

# ── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info

# ── File Storage ───────────────────────────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=5

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Session ────────────────────────────────────────────────────────────────────
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Frontend ───────────────────────────────────────────────────────────────────
# WARNING: Do NOT set VITE_API_URL in development.
# Vite bakes this value into the client JS bundle at build time.
# If set to "localhost", LAN users' browsers will point at their OWN machine.
# Leave unset → frontend uses relative /api paths → Vite proxy handles routing.
# Only set for production with a real domain:
# VITE_API_URL=https://api.juhudikilimo.co.ke
